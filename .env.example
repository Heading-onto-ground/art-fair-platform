# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/artfair"

# ── Session ───────────────────────────────────────────────────────────────────
# REQUIRED in production — minimum 32 random characters
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@rob-roleofbridge.com"
# REQUIRED in production when no DB password hash is set
ADMIN_PASSWORD="change-me-in-production"
# Optional — token for the /api/admin/reset-password endpoint
ADMIN_RESET_TOKEN=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""
FROM_EMAIL="noreply@rob-roleofbridge.com"
CONTACT_EMAIL="contact@rob-roleofbridge.com"

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# REQUIRED in production — passed as Authorization: Bearer <secret>
CRON_SECRET=""
# Optional webhook for gallery crawl notifications
WEBHOOK_URL=""

# ── Storage (Vercel Blob) ─────────────────────────────────────────────────────
# Optional — falls back to base64 storage if not set
BLOB_READ_WRITE_TOKEN=""

# ── Crawlers (all optional) ───────────────────────────────────────────────────
CRAWL_OPENCALLS_ENABLED="1"

# Instagram
CRAWL_INSTAGRAM_ENABLED="1"
INSTAGRAM_ACCESS_TOKEN=""
CRAWL_INSTAGRAM_ACCOUNT_IDS=""
CRAWL_INSTAGRAM_ACCOUNT_META_JSON=""

# Global RSS feeds (comma-separated URLs)
CRAWL_GLOBAL_OC_FEED_URLS=""

# Arthub
CRAWL_ARTHUB_LIST_URLS=""
CRAWL_ARTHUB_CONTACT_EMAIL=""

# Korean blogs
CRAWL_KR_BLOG_FEED_URLS=""
CRAWL_KR_BLOG_PAGE_URLS=""
CRAWL_KR_BLOG_CONTACT_EMAIL=""

# Japan open calls
CRAWL_JP_OC_FEED_URLS=""
CRAWL_JP_OC_PAGE_URLS=""
CRAWL_JP_OC_CONTACT_EMAIL=""
CRAWL_JP_OC_DEFAULT_CITY="Tokyo"
CRAWL_JP_OC_LABEL="Japan Open Call Network"

# Gallery directory
CRAWL_GALLERY_DIRECTORY_ENABLED="1"
CRAWL_GALLERY_EMAIL_DISCOVERY_LIMIT="80"

# ── Mobile (Expo) ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL="http://localhost:3000"
